                        roughness(0.25f)
                    }
                }.transform.translate(x.toFloat(), -1.2f, z.toFloat())
            }
        }

        val wallCells = listOf(
            GridPos(-1, 1),
            GridPos(0, 1),
            GridPos(1, 1),
            GridPos(1, 0)
        )

        for (cell in wallCells) {
            addColorMesh {
                generate { cube { colored() } }
                shader = KslPbrShader {
                    color { vertexColor() }
                    metallic(0f)
                    roughness(0.25f)
                }
            }.transform.translate(cell.x.toFloat(), -1.2f, cell.z.toFloat())
        }

        val playerNode = addColorMesh {
            generate { cube { colored() } }
            shader = KslPbrShader {
                color { vertexColor() }
                metallic(0f)
                roughness(0.25f)
            }
        }

        val alchemistNode = addColorMesh {
            generate { cube { colored() } }
            shader = KslPbrShader {
                color { vertexColor() }
                metallic(0f)
                roughness(0.25f)
            }
        }
        alchemistNode.transform.translate(-3f, 0f, 0f)

        val herbNode = addColorMesh {
            generate { cube { colored() } }
            shader = KslPbrShader {
                color { vertexColor() }
                metallic(0f)
                roughness(0.25f)
            }
        }
        herbNode.transform.translate(3f, 0f, 0f)

        lighting.singleDirectionalLight {
            setup(Vec3f(-1f, -1f, -1f))
            setColor(Color.WHITE, 5f)
        }

        server.start(coroutineScope)
        coroutineScope.launch {
            server.events.collect { event ->
                if (event is VictoryEvent && event.playerId == hud.activePlayerIdFlow.value) {
                    hud.victoryMessage.value = event.message
                    hud.showVictoryPanel.value = true
                    delay(5000)
                    hud.showVictoryPanel.value = false
                }
                if (event is TakeDamage && event.playerId == hud.activePlayerIdFlow.value) {
                    hud.currentHealth.value = event.newHealth
                    hud.maxHealth.value = event.maxHealth
                }
                if (event is HealthChanged && event.playerId == hud.activePlayerIdFlow.value) {
                    hud.currentHealth.value = event.newHealth
                    hud.maxHealth.value = event.maxHealth
                }
            }
        }

        var renderX = 0f
        var renderZ = 0f
        var renderRotate = 0f

        var lastAppliedX = 0f
        var lastAppliedZ = 0f
        var lastAppliedRotate = 0f

        var currentYaw = facingToYawDeg(Facing.FORWARD)

        playerNode.onUpdate {
            val activeId = hud.activePlayerIdFlow.value
            val player = server.getPlayerData(activeId)

            val targetX = player.gridX.toFloat()
            val targetZ = player.gridZ.toFloat()
            val targetRotate = player.rotate

            val speed = Time.deltaT * 8f
            val t = if (speed > 1f) 1f else speed

            renderX = lerp(renderX, targetX, t)
            renderZ = lerp(renderZ, targetZ, t)
            renderRotate = lerp(renderRotate, targetRotate, t)

            val dx = renderX - lastAppliedX
            val dz = renderZ - lastAppliedZ
            val rotateDelta = renderRotate - lastAppliedRotate

            playerNode.transform.translate(dx, 0f, dz)

            if (rotateDelta != 0f) {
                playerNode.transform.rotate(rotateDelta.deg, Vec3f.Y_AXIS)
            }

            val targetYaw = facingToYawDeg(player.facing)
            val yawDelta = targetYaw - currentYaw

            if (yawDelta != 0f) {
                playerNode.transform.rotate(yawDelta.deg, Vec3f.Y_AXIS)
                currentYaw = targetYaw
            }

            lastAppliedX = renderX
            lastAppliedZ = renderZ
            lastAppliedRotate = renderRotate
        }
    }

    addScene {
        setupUiScene(ClearColorLoad)

        hud.activePlayerIdFlow
            .flatMapLatest { pid ->
                server.players.map { map ->
                    map[pid] ?: initialPlayerState(pid)
                }
            }
            .onEach { player ->
                hud.playerSnapShot.value = player
                hud.currentHealth.value = player.health
                hud.maxHealth.value = player.maxHealth
            }
            .launchIn(coroutineScope)

        hud.activePlayerIdFlow
            .flatMapLatest { pid ->
                server.events.filter { it.playerId == pid }
            }
            .map { event -> eventToText(event) }
            .onEach { line ->
                hudLog(hud, "[${hud.activePLayerIdUi.value}] $line")
            }
            .launchIn(coroutineScope)

        addPanelSurface {
            modifier
                .align(AlignmentX.Start, AlignmentY.Top)
                .margin(0.dp)
                .background(RoundRectBackground(Color(0f, 0f, 0f, 0.6f), 14.dp))
                .padding(12.dp)

            Column {
                val player = hud.playerSnapShot.use()
                val dialogue = buildAlchemistDialogue(player)

                Text("Игрок: ${hud.activePLayerIdUi.use()}") { modifier.margin(bottom = sizes.gap) }
                Text("Позиция: x=${player.gridX} z=${player.gridZ}") {}
                Text("Смотрит: ${player.facing}") { modifier.font(sizes.smallText).margin(bottom = sizes.smallGap) }
                Text("Quest State: ${player.questState}") { modifier.font(sizes.smallText) }
                Text(currentObjective(player)) { modifier.font(sizes.smallText) }
                Text(formatInventory(player)) { modifier.font(sizes.smallText).margin(bottom = sizes.smallGap) }
                Text("Gold: ${player.gold}") { modifier.font(sizes.smallText) }
                Text("Hint: ${player.hintText}") { modifier.font(sizes.smallText) }
                Text("Npc Memory: ${formatMemory(player.alchemistMemory)}") {
                    modifier.font(sizes.smallText).margin(bottom = sizes.smallGap)
                }

                Text("Заспавнено кубов: ${hud.spawnedCubeCount.value}") {
                    modifier.font(sizes.smallText).margin(bottom = sizes.smallGap)
                }

                Row {
                    Button("Сменить игрока") {
                        modifier.margin(end = 8.dp).onClick {
                            val newId = if (hud.activePLayerIdUi.value == "Oleg") "Stas" else "Oleg"
                            hud.activePLayerIdUi.value = newId
                            hud.activePlayerIdFlow.value = newId
                        }
                    }
                    Button("Сбросить игрока") {
                        modifier.onClick {
                            server.trySend(CmdResetPlayer(player.playerId))
                        }
                    }
                }

                Text("Движение в мире:") { modifier.margin(top = sizes.gap) }

                Row {
                    Button("Лево") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdStepMove(player.playerId, stepX = -1, stepZ = 0))
                        }
                    }
                    Button("Право") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdStepMove(player.playerId, stepX = 1, stepZ = 0))
                        }
                    }
                    Button("Вперед") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdStepMove(player.playerId, stepX = 0, stepZ = -1))
                        }
                    }
                    Button("Назад") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdStepMove(player.playerId, stepX = 0, stepZ = 1))
                        }
                    }
                }

                var lastCubeY = 0f

                Row {
                    Button("вращать в лево") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdRotate(player.playerId, rotate = -10f))
                        }
                    }
                    Button("вращать в право") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdRotate(player.playerId, rotate = 10f))
                        }
                    }

                    Button("E (добавить кубик)") {
                        modifier.margin(end = 8.dp).onClick {
                            val spawnX = player.gridX.toFloat() + 1f
                            val spawnZ = player.gridZ.toFloat() + 1f
                            val spawnY = lastCubeY
                            lastCubeY += 1.7f

                            gameScene.addColorMesh {
                                generate { cube { colored() } }
                                shader = KslPbrShader {
                                    color { vertexColor() }
                                    metallic(0f)
                                    roughness(0.25f)
                                }
                            }.transform.translate(spawnX, spawnY, spawnZ)

                            val newCount = hud.spawnedCubeCount.value + 1
                            hud.spawnedCubeCount.value = newCount
                            hudLog(hud, "Создан куб #$newCount в ($spawnX, $spawnY, $spawnZ) кнопкой E")
                        }
                    }
                }

                Text("Взаимодействия:") { modifier.margin(top = sizes.gap) }

                Row {
                    Button("Потрогать ближайшего") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdInteract(player.playerId))
                        }
                    }
                    Button("Отнять здоровье") {
                        modifier.margin(end = 8.dp).onClick {
                            server.trySend(CmdDamagePlayer(player.playerId, 10))
                        }
                    }
                }

                Text(dialogue.npcId) { modifier.margin(top = sizes.gap) }
                Text(dialogue.text) { modifier.margin(bottom = sizes.smallGap) }

                if (dialogue.option.isEmpty()) {
                    Text("Нет доступных варинатов ответа") {
                        modifier.font(sizes.smallText).margin(bottom = sizes.gap)
                    }
                } else {
                    Row {
                        for (option in dialogue.option) {
                            Button(option.text) {
                                modifier.margin(end = 8.dp).onClick {
                                    server.trySend(
                                        CmdChooseDialogueOption(
                                            player.playerId,
                                            option.id
                                        )
                                    )
                                }
                            }
                        }
                    }
                }

                Text("Лог: ") { modifier.margin(top = sizes.gap) }

                for (line in hud.log.use()) {
                    Text(line) { modifier.font(sizes.smallText) }
                }
            }
        }
        addPanelSurface {
            modifier
                .align(AlignmentX.End, AlignmentY.Bottom)
                .margin(16.dp)
                .width(200.dp)
                .height(50.dp)
                .background(RoundRectBackground(Color(0f, 0f, 0f, 0.8f), 8.dp))
                .padding(8.dp)

            // ⬇️ Реактивно читаем текущее здоровье
            val currentHealth = hud.currentHealth.use()
            val maxHealth = hud.maxHealth.use()

            Column {
                Text("HP $currentHealth/$maxHealth") {
                    modifier.margin(bottom = 4.dp).font(sizes.smallText)
                }

                Box {
                    modifier
                        .width(184.dp)
                        .height(16.dp)
                        .background(RoundRectBackground(Color.WHITE, 4.dp))

                    val healthPercent = if (maxHealth > 0) {
                        (currentHealth.toFloat() / maxHealth.toFloat()).coerceIn(0f, 1f)
                    } else 0f
                    val healthWidth = 184.dp * healthPercent

                    Box {
                        modifier
                            .align(AlignmentX.Start, AlignmentY.Center)
                            .width(healthWidth)
                            .height(16.dp)
                            .background(RoundRectBackground(Color.RED, 4.dp))
                    }
                }
            }
        }

        if (hud.showVictoryPanel.value == true) {
            addPanelSurface {
                modifier
                    .align(AlignmentX.Center, AlignmentY.Center)
                    .background(RoundRectBackground(Color(0f, 0f, 0f, 0.85f), 0.dp))
                    .padding(32.dp)

                Column {
                    Text(" ПОБЕДА! ") {
                        modifier.margin(bottom = 16.dp)
                    }
                    Text(hud.victoryMessage.use()) {
                        modifier.margin(bottom = 24.dp)
                    }
                }
            }
        }
    }
}
